{
  "_": "managed-by: clawtool — generated by `clawtool recipe apply devcontainer` (Go).",
  "name": "go-dev",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.25-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "eamodio.gitlens"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint"
      }
    }
  },
  "postCreateCommand": "go mod download && go test -count=1 ./... || true",
  "remoteUser": "vscode"
}
