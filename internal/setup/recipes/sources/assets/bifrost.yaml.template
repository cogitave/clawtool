# managed-by: clawtool
# Generated by `clawtool recipe apply bifrost-template`.
# Edits are safe — re-running the recipe refuses to overwrite an
# unmanaged file. Remove the `managed-by: clawtool` line above to
# make this file fully your own.
#
# Bifrost (https://github.com/maximhq/bifrost, Apache-2.0) is a
# Go-native AI gateway: unified failover, semantic caching, and
# budget governance across OpenAI / Anthropic / Vertex / Bedrock /
# local llama backends. clawtool's portal layer registers a
# `bifrost` driver that — when phase 2 lands — reads this file
# and dispatches against the configured provider chain.
#
# Phase 1 (today): the driver returns ErrBifrostDeferred from
# Ask. This template is config-only; nothing actually reads it
# yet. Drop it now so when phase 2 ships behind the
# `clawtool_bifrost` build tag, your provider chain + cache
# settings are already in place.
#
# Phase 2 contract (preview):
#
#   model            — primary model identifier (e.g. "claude-opus-4-7",
#                      "gpt-5", "vertex/gemini-2-pro"). Driver routes
#                      every Ask to this provider first.
#   fallback_chain   — ordered list of secondary providers. Tried
#                      sequentially when the primary fails (rate
#                      limit, 5xx, timeout). Each entry is a model
#                      identifier matching one of the providers
#                      configured below.
#   semantic_cache   — enable Bifrost's semantic-similarity cache.
#                      When true, Ask hashes the prompt against
#                      previous responses and short-circuits on a
#                      similarity hit (default threshold 0.92).
#   budget_usd_daily — soft cap on daily spend across providers.
#                      Driver returns ErrBifrostBudgetExceeded when
#                      the next call would push past the cap.
#
# Provider credentials live in clawtool's secrets.toml under the
# scope `portal.bifrost.<provider>` — same convention as the
# per-portal cookie scopes.

# model: "claude-opus-4-7"
#
# fallback_chain:
#   - "gpt-5"
#   - "vertex/gemini-2-pro"
#
# semantic_cache: true
#
# budget_usd_daily: 50.0
#
# providers:
#   anthropic:
#     api_key_secret: "portal.bifrost.anthropic.api_key"
#   openai:
#     api_key_secret: "portal.bifrost.openai.api_key"
#   vertex:
#     project_id: "your-gcp-project"
#     credentials_secret: "portal.bifrost.vertex.adc_json"
